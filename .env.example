# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/demo_copilot"

# Redis
REDIS_URL="redis://localhost:6379"

# AI
ANTHROPIC_API_KEY="sk-ant-..."
OPENROUTER_API_KEY="..."
OPENROUTER_MODEL="anthropic/claude-3.7-sonnet"

# Voice
ELEVENLABS_API_KEY="..."
ELEVENLABS_VOICE_ID="..."          # Default voice ID

# Storage (choose one)
SUPABASE_URL="..."
SUPABASE_SERVICE_KEY="..."
# OR
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="us-east-1"
AWS_S3_BUCKET="demo-copilot-assets"

# App
API_PORT=3001
WEB_PORT=3000
API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# Stripe (test mode) — create Products/Prices in Dashboard, then paste Price IDs
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_VIDEO_SINGLE="price_..."
STRIPE_PRICE_VIDEO_PACK_5="price_..."
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_TEAM="price_..."
STRIPE_PRICE_AGENCY="price_..."

# Optional: pin a completed project for the landing-page social post preview
# NEXT_PUBLIC_SHOWCASE_PROJECT_ID=""

# Optional: path to ffmpeg binary if not on PATH
# FFMPEG_PATH="C:/path/to/ffmpeg.exe"

# Video output (defaults under ./tmp/demo-copilot-output when unset)
OUTPUT_DIR="./tmp/demo-copilot-output"

# Use silent placeholder audio (skip ElevenLabs). Auto-fallback also runs on 401/402/429.
# VOICE_MOCK=1
VIDEO_RESOLUTION_WIDTH=1920
VIDEO_RESOLUTION_HEIGHT=1080
VIDEO_FPS=30

# Final render: hyperframes | remotion (see Agent_Guardlines_files/SPEC.md §14).
# If HyperFrames CLI is unavailable, the API falls back to FFmpeg timeline compositing.
RENDER_BACKEND="hyperframes"

# HyperFrames CLI (HeyGen): https://hyperframes.heygen.com/quickstart
# Optional override if `npx` is not on PATH in your worker environment.
# HYPERFRAMES_NPX="npx"

# Root folder under OUTPUT_DIR where generated HyperFrames projects live
HYPERFRAMES_PROJECTS_DIR="hyperframes-projects"
